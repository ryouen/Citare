  "must_not_synthesize": [
    {
      "key": "N1_dataset_size_positive_monotonic",
      "template_type": "RELATION",
      "weight": 2.0,
      "forbidden_pattern": {
        "iv_regex": "(dataset[_ ]size|sample[_ ]size|training[_ ]size)",
        "dv_regex": "(test[_ ]accuracy|test[_ ]error|generalization)",
        "relation": "^positive$",
        "verification_status_include": ["verified_in_paper"]
      },
      "exclusion_note": "R3 is non_monotonic. A claim recorded as plain 'positive + verified' for dataset_size -> accuracy is a sanitized synthesis that ignores the crossover. This is the signature LLM-fails-at-middle-reading error.",
      "description": "MUST NOT synthesize a monotonic positive scaling claim ignoring the crossover."
    },
    {
      "key": "N2_larger_models_more_robust",
      "template_type": "RELATION",
      "weight": 2.0,
      "forbidden_pattern": {
        "iv_regex": "(model[_ ]capacity|model[_ ]size|parameters|depth|width|larger[_ ]model)",
        "dv_regex": "(noise[_ ]robust|crossover|n[_\\^]?\\*|test[_ ]accuracy)",
        "relation": "^positive$"
      },
      "exclusion_note": "R5 establishes the opposite: larger models fail EARLIER (smaller n*). A positive-sign claim reflects the LLM's prior, not the paper.",
      "description": "MUST NOT synthesize the common-sense claim that larger models are more noise-robust."
    },
    {
      "key": "N3_bound_fully_validated",
      "template_type": "META_CLAIM",
      "weight": 1.0,
      "forbidden_pattern": {
        "source_text_contains_all_of": ["bound", "empirically", "validated"],
        "source_text_does_not_contain_any_of": ["except", "above", "diverge", "crossover", "regime", "boundary"]
      },
      "exclusion_note": "R7 explicitly states the bound diverges above n*. An unqualified 'bound is empirically validated' claim is a Discussion-sanitization uptake.",
      "description": "MUST NOT record an unqualified 'bound validated' META_CLAIM without mentioning the divergence regime."
    }
  ],

