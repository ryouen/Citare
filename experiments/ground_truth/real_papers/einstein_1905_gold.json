{
  "paper_doi_hint": "10.1002/andp.19053221004",
  "paper_title": "Zur Elektrodynamik bewegter Körper (On the Electrodynamics of Moving Bodies)",
  "paper_author_year": "Einstein 1905",
  "source": "hand-authored from physics domain knowledge",
  "notes": [
    "EXTREME test: German-language scanned PDF with no text layer; 1905 typesetting; physics equations throughout.",
