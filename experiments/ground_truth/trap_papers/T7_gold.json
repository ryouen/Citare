{
  "paper_doi": "10.9999/trap.2024.007",
  "paper_title": "More Data, Worse Models: Non-Monotonic Scaling under Long-Tail Label Noise",
  "paper_author_year": "Okafor, Yang, Patel 2024 (SYNTHETIC TRAP)",
  "source": "synthetic trap paper authored for Citare T7 benchmark on 2026-04-24. Ground truth is authored BEFORE the paper — the paper is a lossy rendering of this fixture.",
  "trap_description": "Tests 6 LLM failure modes on a 30-page ML paper: (F1) Lost-in-the-Middle — critical findings buried at p.15-22, sanitized in Discussion; (F2) False transitive synthesis — A->B and B->C established but A->C direct is null; (F3) Discussion sanitization — Abstract/Discussion soften the counterintuitive middle results; (F4) Common-sense bias — paper's main finding (more data hurts, larger models fail earlier) contradicts standard scaling-law intuition; (F5) Equation fidelity — 7 equations of varying complexity at different positions; (F6) Sign-reversal moderation — crossover behaviour requires catching non-monotonic structure.",

  "position_robustness_note": "Claims whose expected_source_page lies in middle_page_range are classified MIDDLE. Aggregate middle-coverage separately for Lost-in-the-Middle diagnosis. Range chosen as middle 40% of the compiled document.",
  "middle_page_range": [7, 14],
  "total_pages": 21,

  "must_catch_claims": [
    {
      "key": "paper_type_empirical",
      "where": "paper.paper_type",
      "weight": 1.0,
      "must_have": {"value_include": ["empirical"]},
      "expected_source_page": 1,
      "description": "Empirical paper (computational experiments on 3 benchmark datasets)"
    },
    {
      "key": "paper_default_computational",
      "where": "paper.default_causal_strength",
      "weight": 1.0,
      "must_have": {
        "design_basis": "computational_demonstration"
      },
      "expected_source_page": 1,
      "description": "Computational demonstration design"
    },

    {
      "key": "def_long_tail_distribution",
      "template_type": "DEFINITION",
      "weight": 1.0,
      "must_have": {
        "concept_regex": "(long[_ \\-]?tail|power[_ \\-]?law|heavy[_ \\-]?tail)",
        "key_elements_include_any_of": ["exponent", "tau", "power law", "class frequency", "Zipf"]
      },
      "expected_source_page": 5,
      "description": "D1: long-tail class distribution with power-law exponent tau"
    },
    {
      "key": "def_non_uniform_label_noise",
      "template_type": "DEFINITION",
      "weight": 1.5,
      "must_have": {
        "concept_regex": "(non[_ \\-]?uniform.*noise|tail[_ \\-]?concentrat.*noise|class[_ \\-]?dependent.*noise|heterogeneous.*noise)",
        "key_elements_include_any_of": ["per-class", "eta_tail", "eta_head", "head", "tail", "heterogeneous"]
      },
      "expected_source_page": 5,
      "description": "D2: non-uniform (tail-concentrated) label noise with eta_head < eta_tail"
    },
    {
      "key": "def_tail_coverage_metric",
      "template_type": "DEFINITION",
      "weight": 1.5,
      "must_have": {
        "concept_regex": "(tail[_ \\-]?coverage)",
        "key_elements_include_any_of": ["fraction", "tail classes", "threshold", "k samples", "per-class sample"]
      },
      "expected_source_page": 5,
      "description": "D3: tail_coverage — fraction of tail classes with at least k samples. NEW construct. MIDDLE."
    },
    {
      "key": "def_crossover_point_n_star",
      "template_type": "DEFINITION",
      "weight": 2.0,
      "must_have": {
        "concept_regex": "(crossover|n[_\\^]?\\*|inflection|reversal[_ ]point)",
        "key_elements_include_any_of": ["sign change", "derivative", "partial", "non-monotonic", "turning point", "reversal"]
      },
      "expected_source_page": 6,
      "description": "D4: crossover point n* where partial derivative of test error with respect to n changes sign. CRITICAL."
    },
    {
      "key": "def_effective_sample_size_under_noise",
      "template_type": "DEFINITION",
      "weight": 1.0,
      "must_have": {
        "concept_regex": "(effective[_ ]sample[_ ]size|n[_ \\-]?eff|noise[_ \\-]?corrected[_ ]n)",
        "key_elements_include_any_of": ["noise-corrected", "1-2", "eta", "denoising", "shrinkage"]
      },
      "expected_source_page": 6,
      "description": "D5: effective sample size under noise, closed form via (1-2eta)^2 correction"
    },

    {
      "key": "rel_R1_dataset_size_to_tail_coverage",
      "template_type": "RELATION",
      "weight": 1.0,
      "must_have": {
        "iv_regex": "(dataset[_ ]size|sample[_ ]size|training[_ ](set[_ ])?size|training[_ ]sample[_ ]size|n[_ ]samples)",
        "dv_regex": "tail[_ ]coverage",
        "relation": "positive",
        "verification_status_include": ["verified_in_paper"]
      },
      "expected_source_page": 8,
      "description": "R1 (A->B): larger dataset increases tail_coverage. Intuitive chain link."
    },
    {
      "key": "rel_R2_tail_coverage_to_accuracy",
      "template_type": "RELATION",
      "weight": 1.0,
      "must_have": {
        "iv_regex": "tail[_ ]coverage",
        "dv_regex": "(test[_ ]accuracy|test[_ ]error|generalization|accuracy)",
        "relation": "(positive|negative)",
        "verification_status_include": ["verified_in_paper"]
      },
      "expected_source_page": 8,
      "description": "R2 (B->C): higher tail_coverage improves test accuracy. Intuitive chain link."
    },
    {
      "key": "rel_R3_dataset_size_to_accuracy_NON_MONOTONIC",
      "template_type": "RELATION",
      "weight": 3.0,
      "must_have": {
        "iv_regex": "(dataset[_ ]size|sample[_ ]size|training[_ ](set[_ ])?size|training[_ ]sample[_ ]size|n[_ ]samples)",
        "dv_regex": "(test[_ ]accuracy|test[_ ]error|generalization|accuracy)",
        "relation": "(non_monotonic|crossover|u[_ \\-]?shaped|inverted[_ \\-]?u|non[_ \\-]?linear|curvilinear)",
        "verification_status_include": ["verified_in_paper"]
      },
      "expected_source_page": 9,
      "description": "R3 (A->C): non-monotonic. CRITICAL COUNTERINTUITIVE RESULT. MIDDLE. Must capture crossover / non-monotonic / reversal, NOT simply 'positive'."
    },
    {
