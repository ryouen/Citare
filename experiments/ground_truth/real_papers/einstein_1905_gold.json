      "description": "Velocity -> time dilation (moving clocks tick slower)",
      "weight": 2.0
    },
    {
      "key": "rel_length_contraction",
      "template_type": "RELATION",
      "must_have": {
        "iv_regex": "(velocity|speed|motion|gesch)",
        "dv_regex": "(length|rod|size|rigid|Länge|Stab)"
      },
      "description": "Velocity -> length contraction (Lorentz contraction)",
      "weight": 2.0
    },
    {
      "key": "formal_equation_present",
      "template_type": "RELATION",
      "must_have": {
        "iv_regex": "(velocity|speed|motion|gesch|frame|time|length)",
        "dv_regex": "(time|length|clock|rod|simult|frame)"
      },
      "description": "At least one RELATION should have formal equation (time dilation, length contraction, etc.)"
    },
    {
      "key": "exist_simultaneity_relative",
      "template_type": "EXISTENCE_CLAIM",
      "must_have": {
        "phenomenon_regex": "(simultane|gleichzeit|absolute|relative)"
      },
      "description": "Simultaneity is relative (not absolute) - foundational observation"
    }
  ]
