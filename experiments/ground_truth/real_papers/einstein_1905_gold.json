  "must_catch_claims": [
    {
      "key": "paper_title_in_german_or_english",
      "where": "paper.paper_type",
      "must_have": {
        "value_include": ["conceptual", "empirical"]
      },
      "description": "Paper type (could be conceptual for theoretical derivation)"
    },
    {
      "key": "paper_author_einstein",
      "where": "paper.paper_type",
      "must_have": {
        "value_include": ["conceptual", "empirical"]
      },
      "description": "Just checks paper_type was extracted (placeholder)"
    },
    {
      "key": "paper_default_theoretical",
      "where": "paper.default_causal_strength",
      "must_have": {
        "design_basis": "theoretical"
      },
      "description": "design_basis = theoretical (no experimental data, pure derivation)",
      "weight": 2.0
    },
    {
      "key": "def_relativity_principle",
      "template_type": "DEFINITION",
      "must_have": {
        "concept_regex": "(relativity|relativity_principle|principle_of_relativity|relativitätsprinzip)"
      },
      "description": "Principle of relativity: laws of physics same in all inertial frames",
      "weight": 2.0
    },
    {
      "key": "def_light_speed_constancy",
      "template_type": "DEFINITION",
      "must_have": {
        "concept_regex": "(light|speed_of_light|light_speed|lichtgeschwindigkeit|constancy|invariant)"
      },
      "description": "Constancy of the speed of light (second postulate)"
    },
    {
      "key": "rel_time_dilation",
      "template_type": "RELATION",
      "must_have": {
        "iv_regex": "(velocity|speed|motion|movement|gesch)",
