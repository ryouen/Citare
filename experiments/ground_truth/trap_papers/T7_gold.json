      "template_type": "RELATION",
      "weight": 1.5,
      "must_have": {
        "iv_regex": "(noise|eta|tail[_ ]exponent|tau)",
        "dv_regex": "(crossover|n[_\\^]?\\*|reversal)",
        "verification_status_include": ["verified_in_paper"]
      },
      "expected_source_page": 10,
      "description": "R4: noise rate and tail exponent jointly determine crossover point n*. Interaction."
    },
    {
      "key": "rel_R5_capacity_to_n_star_COUNTERINTUITIVE",
      "template_type": "RELATION",
      "weight": 2.5,
      "must_have": {
        "iv_regex": "(model[_ ]capacity|model[_ ]size|parameters|depth|width)",
        "dv_regex": "(crossover|n[_\\^]?\\*|reversal[_ ]point)",
        "relation": "negative",
        "verification_status_include": ["verified_in_paper"]
      },
      "expected_source_page": 10,
      "description": "R5: larger models have SMALLER n* (fail earlier). CRITICAL COUNTERINTUITIVE SECOND RESULT. MIDDLE."
