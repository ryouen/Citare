    {
      "key": "rel_R6_bound_vs_empirical_before_nstar",
      "template_type": "RELATION",
      "weight": 1.0,
      "must_have": {
        "iv_regex": "(bound|prediction|theoretical|theory)",
        "dv_regex": "(empirical|measured|observed)",
        "verification_status_include": ["verified_in_paper"]
      },
      "expected_source_page": 9,
      "description": "R6: bound tracks empirical error BELOW n*. Scope-limited agreement."
    },
    {
      "key": "rel_R7_bound_diverges_above_nstar",
      "template_type": "RELATION",
      "weight": 2.0,
      "must_have": {
        "iv_regex": "(bound|prediction|theoretical|theory)",
        "dv_regex": "(empirical|measured|observed|error)",
        "verification_status_include": ["verified_in_paper", "partial_support", "mixed_support"]
      },
      "expected_source_page": 12,
      "description": "R7: bound DIVERGES from empirical above n*. Discussion softens this; faithful extraction must keep the divergence."
    },
    {
      "key": "rel_R8_regularization_to_n_star",
      "template_type": "RELATION",
      "weight": 1.0,
      "must_have": {
        "iv_regex": "(regulariz|weight[_ ]decay|l2|penalty)",
        "dv_regex": "(crossover|n[_\\^]?\\*)",
        "relation": "positive",
        "verification_status_include": ["verified_in_paper"]
      },
      "expected_source_page": 12,
      "description": "R8: stronger regularization pushes n* later (delays the crossover)."
